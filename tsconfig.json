{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": [
    "*.ts",
    "agents/**/*.ts",
    "tools/**/*.ts",
    "notifications/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
